@model IEnumerable<Lesson6.Models.Student>
<h2>Danh sách sinh viên</h2>

<a href="/Student/Create">Thêm sinh viên</a>

<table border="1">
<tr>
    <th>ID</th>
    <th>Name</th>
    <th>Age</th>
    <th>Class</th>
</tr>

@foreach (var item in Model)
{
<tr>
    <td>@item.Id</td>
    <td>@item.FullName</td>
    <td>@item.Age</td>
    <td>@item.Class</td>
</tr>
}

</table>